# Copy this file to .env and fill in values for your local setup.
# .env is gitignored; this file is safe to commit.

# Name of the Obsidian vault folder (relative to server.py)
VAULT_DIR=choracle-remote-00

# Ollama endpoint and model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2          # alternatives: mistral, llama3.1, phi3

# Smart Connections embedding model key (must match what the plugin used)
EMBED_MODEL_KEY=TaylorAI/bge-micro-v2

# spaCy language model (must be downloaded: python -m spacy download en_core_web_sm)
SPACY_MODEL=en_core_web_sm     # alternatives: en_core_web_md, en_core_web_lg
