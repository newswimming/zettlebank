{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2018",
		"allowJs": true,
		"noImplicitAny": true,
		"moduleResolution": "node",
		"isolatedModules": true,
		"strictNullChecks": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "ES2018", "ES2021.String"]
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules"]
}
